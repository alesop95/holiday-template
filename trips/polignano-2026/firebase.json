{
  "hosting": {
    "target": "polignano-2026",
    "public": ".",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**", "_trip-notes/**"],
    "rewrites": [{ "source": "**", "destination": "/index.html" }],
    "headers": [
      {
        "source": "**/*.@(html|js)",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, max-age=0" }]
      }
    ]
  }
}
